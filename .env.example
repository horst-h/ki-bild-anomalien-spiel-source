PORT=3001
ADMIN_PASSWORD=changeme
SESSION_SECRET=dev-secret-change-me

# Google Perspective API – zweite Prüfstufe für Spielernamen (optional).
# Ohne Key wird die API-Prüfung übersprungen; lokale Blockliste bleibt aktiv.
# Key: https://developers.google.com/codelabs/setup-perspective-api
PERSPECTIVE_API_KEY=
# Schwellenwert 0..1, ab dem ein Name als unzulässig gilt (Default: 0.7)
PERSPECTIVE_THRESHOLD=0.7
# Komma-getrennte Sprachcodes für die Analyse (Default: de,en)
PERSPECTIVE_LANGUAGES=de,en
